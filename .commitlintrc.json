{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "refactor", "test", "docs", "chore", "build", "ci", "perf", "revert"]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "core",
        "trace",
        "perception",
        "executor",
        "verifier",
        "reasoning",
        "orchestrator",
        "server",
        "widget",
        "trace-viewer",
        "eval",
        "fixture-site",
        "demo-host",
        "root",
        "deps",
        "release"
      ]
    ],
    "scope-empty": [2, "never"],
    "subject-empty": [2, "never"],
    "subject-max-length": [2, "always", 100]
  }
}
