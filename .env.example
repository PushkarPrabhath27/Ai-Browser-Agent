# ============================================================================
# Embeddable AI Web Agent — environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values you need. Never commit a
# real `.env` to the repo — `.env` is gitignored.
#
# Reasoning engine selection (test-only profiles are zero-cost and zero-footprint):
#   - "scripted-fake" : hand-coded synthetic provider; used by all unit/integration tests.
#   - "fixture-replay": replays recorded JSON cassettes; zero network.
#   - "gemini"        : Google Gemini API (free tier); default for live runs and Phase 9 eval.
#   - "groq"          : Groq API (free tier); OpenAI-compatible endpoint, fast inference.
#   - "claude"        : Anthropic Claude API.
#   - "openai"        : OpenAI API.
#   - "ollama"        : Local model server. OPT-IN ONLY — requires 4-8GB local weight
#                       download per model. Not used in CI by default.
#   - "nvidia-nim"    : Nvidia NIM (OpenAI-compatible) endpoint, if configured.
# ============================================================================

REASONING_PROVIDER=gemini

# API keys (unused for scripted-fake / fixture-replay / ollama)
REASONING_API_KEY=

# Model identifiers (provider-specific defaults applied if blank)
REASONING_MODEL=
GEMINI_MODEL=gemini-1.5-flash
GROQ_MODEL=llama-3.1-70b-versatile
CLAUDE_MODEL=claude-3-5-sonnet-latest
OPENAI_MODEL=gpt-4o-mini
NVIDIA_NIM_MODEL=

# Custom endpoints (for self-hosted providers)
OLLAMA_BASE_URL=http://localhost:11434
NVIDIA_NIM_BASE_URL=

# ----- Safety policy & budgets -----
DATABASE_PATH=./data/trace.db

# Comma-separated host/domain allowlist for navigation actions.
ALLOWED_DOMAINS=localhost,127.0.0.1,fixture-site.local

# Keywords that trigger require_approval in the safety gate (comma-separated, matched
# against accessible name + role + form field heuristics).
SENSITIVE_ACTION_KEYWORDS=confirm purchase,place order,delete account,submit payment,transfer funds

# Hard caps. Any of these being hit causes ABORT_TASK.
MAX_STEPS_PER_TASK=40
MAX_RETRIES_PER_STEP=2
MAX_REPLANS_PER_TASK=3
MAX_WALL_CLOCK_MS=300000
MAX_MODEL_CALLS_PER_TASK=60

# ----- Server -----
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
LOG_LEVEL=info
RATE_LIMIT_PER_IP_PER_HOUR=10
